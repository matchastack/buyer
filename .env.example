# Lazada SG account credentials
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.
#
# These values are loaded at runtime via process.env.
# They are NEVER stored in config.json.

LAZADA_EMAIL=your@email.com
LAZADA_PASSWORD=your_password_here

# Optional: enable mobile approval via Telegram.
# Only required when settings.approvalMethod = "telegram" in config.json.
# 1. Create a bot with @BotFather on Telegram, copy the token below.
# 2. Send your bot any message, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: route the browser through a residential proxy to avoid anti-bot
# blocks (datacenter IPs are flagged almost instantly under repeated polling).
# Leave ALL THREE blank to run without a proxy. If you set any, set all three.
#
# Recommended: a Singapore residential STICKY session (one IP for the whole run —
# rotating mid-session would break your logged-in cookies). Example with Decodo:
#   PROXY_SERVER=gate.decodo.com:7000
#   PROXY_USERNAME=user-<your-user>-country-sg-sessionduration-60
#   PROXY_PASSWORD=<your-proxy-password>
# The server (host:port) may instead live in config.json as settings.proxy.server;
# the username/password are ALWAYS env-only and never stored in config.json.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

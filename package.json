{
  "name": "pokemon-center-buyer",
  "version": "2.0.0",
  "description": "Automated monitor and checkout assistant for Pokemon Center SG on Lazada",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dry-run": "node dist/index.js --dry-run",
    "dev": "ts-node src/index.ts",
    "dev:dry-run": "ts-node src/index.ts --dry-run",
    "verify-selectors": "ts-node src/index.ts --dry-run --verify-selectors",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "playwright": "1.56.1"
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
